# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/bluemoon_db
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# Gmail SMTP Configuration
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Sepay Payment Provider Configuration
SEPAY_BANK_ACCOUNT=your_bank_account_here
SEPAY_BANK_CODE=MB
SEPAY_ACCOUNT_NAME=your_account_name_here
SEPAY_WEBHOOK_API_KEY=your_webhook_api_key_here
# SEPAY_WEBHOOK_HMAC_SECRET=your_hmac_secret_here
SEPAY_INVOICE_EXPIRATION_MINUTES=15

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here